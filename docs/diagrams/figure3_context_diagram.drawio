        <mxCell id="proc0num" value="0" style="text;html=1;align=left;verticalAlign=top;fontSize=16;fontStyle=1;fontColor=#1B2F72;" vertex="1" parent="1">
          <mxGeometry x="440" y="368" width="30" height="24" as="geometry" />
        </mxCell>

        <!-- External entities -->
        <mxCell id="entDriver" value="AUTHORIZED DRIVER" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8ECF6;strokeColor=#1B2F72;strokeWidth=2;shadow=1;fontSize=13;fontStyle=1;fontColor=#0F172A;" vertex="1" parent="1">
