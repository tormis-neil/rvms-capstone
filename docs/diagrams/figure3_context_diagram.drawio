<mxfile host="app.diagrams.net" type="device">
  <diagram name="Figure 3 - Context Diagram" id="rvms-context">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Process 0 : the whole system -->
        <mxCell id="proc0" value="RESCUE VEHICLE&#10;MANAGEMENT SYSTEM" style="rounded=1;arcSize=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B2F72;strokeWidth=2;fontSize=15;fontStyle=1;fontColor=#0F172A;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="430" y="360" width="260" height="120" as="geometry" />
