          <mxGeometry x="450" y="660" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Data flows -->
        <mxCell id="e1" value="Login Credentials, Registration Request,&#10;Inspection Submission, Damage Report,&#10;Profile Update" style="endArrow=block;html=1;rounded=0;strokeColor=#222222;strokeWidth=1.2;fontSize=11;fontColor=#0F172A;labelBackgroundColor=#FFFFFF;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entDriver" target="proc0">
