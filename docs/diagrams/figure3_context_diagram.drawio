        <mxCell id="e2" value="Assigned Vehicle Information,&#10;Driver Notification" style="endArrow=block;html=1;rounded=0;strokeColor=#222222;strokeWidth=1.2;fontSize=11;fontColor=#0F172A;labelBackgroundColor=#FFFFFF;exitX=0.05;exitY=0.5;exitDx=0;exitDy=0;entryX=0.55;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="proc0" target="entDriver">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="Login Credentials, Vehicle and Driver Record,&#10;Maintenance and Dispatch Record,&#10;Driver Access Approval, Report Request" style="endArrow=block;html=1;rounded=0;strokeColor=#222222;strokeWidth=1.2;fontSize=11;fontColor=#0F172A;labelBackgroundColor=#FFFFFF;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entAdmin" target="proc0">
